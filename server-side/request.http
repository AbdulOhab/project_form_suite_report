    "userName": "New Zonal User",
    "email": "newzonal@test.com",
    "password": "1122",
    "zonalCode": 203,
    "userRole": "zonal"
}

### Get Zonal Users
GET {{hostName}}/get-zonal-users/201
Authorization: Bearer {{gsmToken}}

### Update Zonal User
