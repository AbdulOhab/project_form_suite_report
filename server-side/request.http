    "email": "newbranch@test.com",
    "password": "1122",
    "branchCode": 303,
    "zonalCode": 201,
    "userRole": "branch"
}

### Get Branch Users
POST {{hostName}}/get-branch-users/201
Authorization: Bearer {{gsmToken}}
Content-Type: application/json

{}

### Get Thana Users for Update
POST {{hostName}}/get-thana-users-for-update/301
Authorization: Bearer {{gsmToken}}

### Update Branch User
