POST {{hostName}}/delete-zonal-users/203
Authorization: Bearer {{gsmToken}}

# ==========================================
# FILE UPLOAD
# ==========================================

### Upload User File
# Change file path to your actual CSV/Excel file
POST {{hostName}}/upload-user-file
Authorization: Bearer {{gsmToken}}
Content-Type: multipart/form-data; boundary=Boundary

--Boundary
Content-Disposition: form-data; name="file"; filename="users.csv"
Content-Type: text/csv

< ./model/seeders/thanaSeeder.js
--Boundary--
