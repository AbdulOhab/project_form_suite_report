# ============================================
# Instance Report API - Test Collection
# ============================================
# How to use:
# 1. First run "Login - Admin" request to get token
# 2. Copy the token from response
# 3. Paste it in @gsmToken variable below
# 4. Click "Send Request" above any request
# ============================================

# ---------- Variables ----------
@hostName = http://localhost:5053
@gsmToken = PASTE_YOUR_TOKEN_HERE
@noticeId = YOUR_NOTICE_ID
@answerId = YOUR_ANSWER_ID

# ==========================================
# AUTH - Login (No token needed)
# ==========================================

### Login - Admin
POST {{hostName}}/submit
Content-Type: application/json

{
    "userId": 110011,
    "password": "1122"
}

### Login - Thana User
POST {{hostName}}/submit
Content-Type: application/json

{
    "userId": 401,
    "password": "1122"
}

### Login - Branch User
POST {{hostName}}/submit
Content-Type: application/json

{
    "userId": 301,
    "password": "1122"
}

### Login - Zonal User
POST {{hostName}}/submit
Content-Type: application/json

{
    "userId": 201,
    "password": "1122"
}

# ==========================================
# AUTH CHECK (Token required)
# ==========================================

### Check logged-in user
GET {{hostName}}/check-user
Authorization: Bearer {{gsmToken}}

### Logout
GET {{hostName}}/logout
Authorization: Bearer {{gsmToken}}

# ==========================================
# NOTICE BOARD
# ==========================================

### Create Notice
POST {{hostName}}/create-notice/110011
Authorization: Bearer {{gsmToken}}
Content-Type: application/json

{
    "noticeId": "notice_001",
    "title": "Test Notice",
    "deadline": "2026-06-30",
    "questions": ["Question 1?", "Question 2?"]
}

### Get Notice
GET {{hostName}}/get-notice/{{noticeId}}
Authorization: Bearer {{gsmToken}}

### Update Notice
POST {{hostName}}/update-notice/{{noticeId}}
Authorization: Bearer {{gsmToken}}
Content-Type: application/json

{
    "title": "Updated Notice",
    "deadline": "2026-07-15"
}

### Delete Notice
POST {{hostName}}/delete-notice/{{noticeId}}
Authorization: Bearer {{gsmToken}}

### Get All Notices
POST {{hostName}}/all-notice
Authorization: Bearer {{gsmToken}}
Content-Type: application/json

{}

# ==========================================
# ANSWERS
# ==========================================

### Create Answer
POST {{hostName}}/create-answer/{{noticeId}}
Authorization: Bearer {{gsmToken}}
Content-Type: application/json

{
    "answers": ["Answer 1", "Answer 2"]
}

### Get Answer
GET {{hostName}}/get-answer/{{answerId}}
Authorization: Bearer {{gsmToken}}

### Get Questions for Notice
GET {{hostName}}/get-question/{{noticeId}}
Authorization: Bearer {{gsmToken}}

### Update Answer
POST {{hostName}}/update-answer/{{answerId}}
Authorization: Bearer {{gsmToken}}
Content-Type: application/json

{
    "answers": ["Updated Answer 1", "Updated Answer 2"]
}

### Get Branch Notice Answers
GET {{hostName}}/notice-answer/branch
Authorization: Bearer {{gsmToken}}

# ==========================================
# DATA CHECK - Thana
# ==========================================

### Thana Data Checkout
GET {{hostName}}/thana/data-checkout/{{noticeId}}
Authorization: Bearer {{gsmToken}}

### Thana Find Data (specific day)
GET {{hostName}}/thana/find-data-checkout/{{noticeId}}/1
Authorization: Bearer {{gsmToken}}

# ==========================================
# DATA CHECK - Branch
# ==========================================

### Branch Data Checkout
GET {{hostName}}/branch/data-checkout/1/{{noticeId}}
Authorization: Bearer {{gsmToken}}

### Branch Data Interface
GET {{hostName}}/branch/data-interface/{{noticeId}}
Authorization: Bearer {{gsmToken}}

# ==========================================
# DATA CHECK - Zonal
# ==========================================

### Zonal Data Checkout
GET {{hostName}}/zonal/data-checkout/1/{{noticeId}}
Authorization: Bearer {{gsmToken}}

### Zonal Data Interface
GET {{hostName}}/zonal/data-interface/{{noticeId}}
Authorization: Bearer {{gsmToken}}

### Zonal Day Count
GET {{hostName}}/zonal/zonal-data-daycount/1/301/{{noticeId}}
Authorization: Bearer {{gsmToken}}

# ==========================================
# DATA CHECK - Admin
# ==========================================

### Admin Data Interface
GET {{hostName}}/admin/data-interface/{{noticeId}}
Authorization: Bearer {{gsmToken}}

### Admin Data Checkout
GET {{hostName}}/admin/data-checkout/1/{{noticeId}}
Authorization: Bearer {{gsmToken}}

### Admin Branch Data Checkout
GET {{hostName}}/admin/branch/data-checkout/1/201/{{noticeId}}
Authorization: Bearer {{gsmToken}}

### Admin Thana Day Count
GET {{hostName}}/admin/thana-data-daycount/1/201/301/{{noticeId}}
Authorization: Bearer {{gsmToken}}

### Admin Get All Branches
GET {{hostName}}/admin/get-all-branches/{{noticeId}}/1
Authorization: Bearer {{gsmToken}}

# ==========================================
# SUMS DATA - Reports
# ==========================================

### Sums Zonal Data
GET {{hostName}}/sums-zonal-data/{{noticeId}}
Authorization: Bearer {{gsmToken}}

### Sums Branch Data
GET {{hostName}}/sums-branch-data/{{noticeId}}
Authorization: Bearer {{gsmToken}}

### Sums Total Days Branch Data
GET {{hostName}}/sums-total-days-branch-data/{{noticeId}}/201/301
Authorization: Bearer {{gsmToken}}

### Sums Day by Day Zonal Data
GET {{hostName}}/sums-day-by-day-zonal-data/{{noticeId}}/201
Authorization: Bearer {{gsmToken}}

### Sums Zonal Data by Branch
GET {{hostName}}/sums-zonal-data-by-branch/{{noticeId}}/201
Authorization: Bearer {{gsmToken}}

### Sums Thana by Branch Data
GET {{hostName}}/sums-thana-by-branch-data/{{noticeId}}/301
Authorization: Bearer {{gsmToken}}

### Sums Thana Data
GET {{hostName}}/sums-thana-data/{{noticeId}}
Authorization: Bearer {{gsmToken}}

### Sums Total Day Thana Data
GET {{hostName}}/sums-Totol-day-thana-data/{{noticeId}}/201/301/401
Authorization: Bearer {{gsmToken}}

# ==========================================
# USER MANAGEMENT - Thana
# ==========================================

### Create Thana User
POST {{hostName}}/create-thana-users
Authorization: Bearer {{gsmToken}}
Content-Type: application/json

{
    "userName": "New Thana User",
    "email": "newthana@test.com",
    "password": "1122",
    "thanaCode": 403,
    "branchCode": 301,
    "zonalCode": 201,
    "userRole": "thana"
}

### Get Thana Users by Branch
GET {{hostName}}/get-thana-users/301
Authorization: Bearer {{gsmToken}}

### Update Thana User
POST {{hostName}}/update-thana-users/403
Authorization: Bearer {{gsmToken}}
Content-Type: application/json

{
    "userName": "Updated Thana User",
    "email": "updated@test.com"
}

### Update Thana Password
POST {{hostName}}/update-thana-password/403
Authorization: Bearer {{gsmToken}}
Content-Type: application/json

{
    "password": "newpassword"
}

### Delete Thana User
POST {{hostName}}/delete-thana-users/403
Authorization: Bearer {{gsmToken}}

# ==========================================
# USER MANAGEMENT - Branch
